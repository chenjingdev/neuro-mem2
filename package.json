{
  "name": "nero-mem2",
  "version": "0.1.0",
  "description": "Local memory infrastructure for AI conversations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "node scripts/dev-all.mjs",
    "dev:server": "npx tsx src/cli.ts",
    "dev:web": "npm --prefix web run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "keywords": [
    "ai",
    "memory",
    "conversation",
    "sqlite"
  ],
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@mariozechner/pi-ai": "^0.58.4",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.12.8",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
